private static int linearSearch(int[] arr, int n, int key) {
	 //Start Traversing from the 1st element (0th index)
	for (int i = 0; i < n; i++) {
		//Compare each element with key sequentially till match is not fount or till the last index.
		if ( key == arr[i] )  //If matched, then return the index.
				return i;
	}	
	return -1;
}
